{
  "name": "@ha-designer/desktop",
  "version": "0.5.0-alpha.1",
  "private": true,
  "description": "Electron shell for ha-ai-designer. Spawns daemon + web, opens a BrowserWindow.",
  "main": "./dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder --win --x64 --publish never",
    "package:mac": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "@ha-designer/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "5.6.3"
  }
}
