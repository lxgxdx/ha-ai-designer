# hha-ai-designer .npmrc
#
# pnpm 10 changed two defaults that broke `pnpm install` for our
# transitive type deps. The fixes here are project-level so every
# contributor (and CI) gets the same install behavior without
# remembering the flags.

# v0.3.0.1: pnpm 10 defaults auto-install-peers=false. With it on,
# @types/express's peer transitive types (@types/express-serve-static-core,
# @types/serve-static, @types/body-parser, @types/qs) are not pulled
# in automatically, and `tsc` reports them as missing — the historic
# 114 errors in apps/daemon. With auto-install-peers=true, those
# resolve at install time. See CLAUDE.md "Docker build 关键教训" for
# the pnpm guard rationale.
auto-install-peers=true

# v0.3.0.1: pnpm 10 also defaults `onlyBuiltDependencies=[]`, which
# blocks lifecycle scripts of native packages — including
# `better-sqlite3`'s `prebuild-install || node-gyp rebuild` hook that
# downloads (or compiles) the platform-specific .node binary. Without
# this, `pnpm install` finishes cleanly but `import 'better-sqlite3'`
# at runtime fails with "Could not locate the bindings file".
#
# On Linux/macOS prebuild-install fetches a precompiled binary; on
# Windows it falls back to node-gyp + Visual Studio Build Tools 2022+.
# See CLAUDE.md 14 课 #2 for the Windows detail.
#
# v0.5.0: added electron — its postinstall fetches the ~100MB
# electron prebuilt binary. Without this allowlist, pnpm 10
# skips the postinstall and Electron can't run.
onlyBuiltDependencies[]=better-sqlite3
onlyBuiltDependencies[]=electron
onlyBuiltDependencies[]=esbuild
