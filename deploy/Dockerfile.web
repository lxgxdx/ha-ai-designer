# Web image — Next.js 14 production build.
#
# In v0.1 we keep it simple: standalone build with daemon URL baked at runtime
# via HA_DAEMON_URL env (Next.js reads process.env on the server).

FROM node:24-alpine AS base
ENV PNPM_HOME=/pnpm PATH=/pnpm/bin:$PATH
RUN corepack enable && corepack prepare pnpm@10.33.2 --activate

WORKDIR /app

COPY pnpm-workspace.yaml package.json ./
COPY pnpm-lock.yaml* ./
COPY apps/daemon/package.json ./apps/daemon/
COPY apps/web/package.json ./apps/web/
COPY packages/contracts/package.json ./packages/contracts/
COPY tools/dev/package.json ./tools/dev/

RUN pnpm install --frozen-lockfile --prod=false

COPY tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
COPY tools ./tools

WORKDIR /app/apps/web
ENV NODE_ENV=production HA_WEB_PORT=3000
RUN pnpm build

EXPOSE 3000
CMD ["pnpm", "start"]
