# Local dev / single-host Docker example.
# Copy to .env and adjust.

# Bind interface for the daemon (loopback only unless you set up a tunnel)
HA_DAEMON_HOST=127.0.0.1
HA_DAEMON_PORT=7456

# Web UI
HA_WEB_PORT=3000

# Persistent data dir (mounted into the container in docker-compose.yml)
HA_DATA_DIR=./data

# Pretty logs in dev, JSON in prod
HA_LOG_PRETTY=1
HA_LOG_LEVEL=info

# Future: HA connection (long-lived token, base URL)
# HA_BASE_URL=http://homeassistant.local:8123
# HA_TOKEN=replace-me
