# Build context exclusions.
#
# BuildKit on Windows cannot traverse symlinks in node_modules (the
# pnpm-workspace.yaml + per-package @ha-designer/contracts link trick).
# We therefore exclude ALL node_modules and re-create them via
# `pnpm install` inside the Linux build container.

# Per-package
**/node_modules

# Build artifacts (re-built inside the container)
**/.next
**/dist
**/.turbo

# Local data (gitignored anyway, but explicit is safer)
data/
hha-knowledge/

# Git
.git
.github

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test artifacts
coverage/
.nyc_output/

# Misc
.env
.env.local
.env.*.local
